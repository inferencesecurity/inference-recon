# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Claude Code local config (permissions, lock files — not for source control)
.claude/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
.python-version

# Node (in case rule packs ship with helper scripts)
node_modules/
npm-debug.log*

# Test target repos (cloned locally for eval, not tracked in this repo)
test-targets/

# Corpus — cloned repos and generated findings (tracked in DB, not git)
eval/corpus/repos/
eval/corpus/findings/

# Eval database (generated data — not tracked)
eval/db/*.db
eval/db/*.db-shm
eval/db/*.db-wal

# Output artifacts from local scans (don't accidentally commit a real scan)
/scan-output/
*.scan.json
*.scan.md

# Environment / secrets — defense in depth even though the repo shouldn't have any
.env
.env.local
.env.local
*.pem
*.key
